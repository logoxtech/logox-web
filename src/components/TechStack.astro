---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const techs = ["n8n", "Docker", "Python", "Chatwoot", "Astro", "AWS"];
---

<section class="w-full relative py-20 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900/40 via-[#09090B] to-[#09090B]">
	<div class="max-w-4xl mx-auto px-4 text-center">
		<h2 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight">
			{t('stack.title')}
		</h2>
		<p class="text-zinc-400 text-lg mb-10 max-w-xl mx-auto">
			{t('stack.subtitle')}
		</p>
		
		<div class="flex flex-wrap justify-center gap-4">
			{techs.map(tech => (
				<span class="px-5 py-2.5 rounded-full border border-zinc-800 bg-zinc-900/50 text-zinc-300 text-sm font-mono hover:border-[#F97316] hover:text-[#F97316] hover:scale-105 transition-all duration-300 cursor-default">
					{tech}
				</span>
			))}
		</div>
	</div>
</section>
