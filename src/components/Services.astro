---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
	{ 
		title: t('service1.title'), 
		desc: t('service1.desc'), 
		tech: '// Powered by n8n, Python',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>',
		snapshotLines: ['➜ ~ target: crm_inventory_sync', '> parsing operational graph [OK]', '> hyper-automation cycle... ACTIVE']
	},
	{
		title: t('service2.title'), 
		desc: t('service2.desc'), 
		tech: '// Engine: OpenAI, WebSocket',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>',
		snapshotLines: ['➜ ~ deploy lead_quali_bot', '> mapping user intents array...', '> conversation vector matched: TRUE']
	},
	{
		title: t('service3.title'), 
		desc: t('service3.desc'), 
		tech: '// Engine: LangChain, PgVector',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>',
		snapshotLines: ['➜ ~ query: resolve_support_issue', '> scanning knowledge base... 100%', '> optimal resolution generated.']
	},
	{
		title: t('service4.title'), 
		desc: t('service4.desc'), 
		tech: '// Native: Astro, React',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>',
		snapshotLines: ['➜ ~ build web_platform --scale', '> compiling static assets...', '> deploying global edges... DONE']
	},
	{
		title: t('service5.title'), 
		desc: t('service5.desc'), 
		tech: '// Infrastructure: Stripe, Next.js',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>',
		snapshotLines: ['➜ ~ init global_checkout', '> routing multi-currency gateway...', '> 256-bit secure transaction [OK]']
	},
	{
		title: t('service6.title'), 
		desc: t('service6.desc'), 
		tech: '// Architecture: Docker, AWS',
		icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>',
		snapshotLines: ['➜ ~ docker-compose up --scale=100', '> mounting cloud volumes...', '> container replicas running: 100/100']
	}
];
---

<section class="max-w-7xl mx-auto px-4 py-24 relative z-10">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-extrabold mb-6 text-transparent bg-clip-text bg-gradient-to-br from-zinc-100 via-zinc-200 to-zinc-500 tracking-tight">
			{t('new_services.title')}
		</h2>
		<p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
			{t('new_services.subtitle')}
		</p>
	</div>
	
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
		{services.map(service => (
			<div class="bg-[#1A1A1D]/50 backdrop-blur-md border border-zinc-700/50 rounded-3xl p-8 hover:border-[#F97316]/50 hover:shadow-[0_0_40px_rgba(249,115,22,0.1)] transition-all duration-500 group flex flex-col relative overflow-hidden">
				<!-- Top gradient highlight -->
				<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-zinc-700/50 to-transparent"></div>
				
				<div class="mb-6 flex items-center justify-between">
					<div class="p-3 bg-zinc-800/50 rounded-xl text-[#10B981] group-hover:text-[#F97316] transition-colors duration-500" set:html={service.icon} />
				</div>
                
				<h3 class="text-2xl font-semibold text-zinc-200 mb-3 group-hover:text-[#10B981] transition-colors duration-300">
					{service.title}
				</h3>
				<p class="text-zinc-400 leading-relaxed mb-8 flex-grow">
					{service.desc}
				</p>
				
				<!-- Visual Snapshot -->
				<div class="w-full bg-[#09090B] rounded-xl border border-zinc-800/80 p-4 mb-6 relative overflow-hidden group-hover:border-zinc-700 transition-colors">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#10B981] to-[#F97316] opacity-30 group-hover:opacity-70 transition-opacity"></div>
					<div class="flex gap-1.5 mb-3">
						<div class="w-2.5 h-2.5 rounded-full bg-zinc-700 group-hover:bg-red-500/80 transition-colors"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-zinc-700 group-hover:bg-yellow-500/80 transition-colors"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-zinc-700 group-hover:bg-green-500/80 transition-colors"></div>
					</div>
					<div class="font-mono text-[11px] md:text-xs text-zinc-500 space-y-1.5">
						<p><span class="text-[#F97316]">➜</span> <span class="text-zinc-400">{service.snapshotLines[0].substring(2)}</span></p>
						<p>{service.snapshotLines[1]}</p>
						<p class="text-[#10B981]">{service.snapshotLines[2]}</p>
					</div>
				</div>

				<!-- Subtle tech reference -->
				<div class="mt-auto border-t border-zinc-800/50 pt-5">
					<p class="text-zinc-600 font-mono text-[10px] uppercase tracking-wider">
						{service.tech}
					</p>
				</div>
			</div>
		))}
	</div>
</section>
