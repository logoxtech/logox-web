---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="max-w-5xl mx-auto px-4 py-24 relative" id="contact">
	<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
		<div class="w-full max-w-xl h-64 bg-[#10B981]/10 blur-[80px] rounded-full"></div>
	</div>
	
	<div class="relative bg-zinc-900/40 backdrop-blur-md border border-zinc-800 rounded-3xl p-10 md:p-16 text-center shadow-2xl overflow-hidden">
		<!-- Subtle top highlight for glassmorphism -->
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-zinc-700/50 to-transparent"></div>
		
		<h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight text-white relative z-10">
			{t('cta.title')}
		</h2>
		<p class="text-zinc-400 text-lg md:text-xl mb-10 max-w-2xl mx-auto relative z-10">
			{t('cta.desc')}
		</p>
		<button class="open-contact-modal inline-block bg-[#F97316] hover:bg-orange-600 text-white px-8 py-4 rounded-xl font-semibold transition-all duration-300 shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:shadow-[0_0_30px_rgba(249,115,22,0.5)] transform hover:-translate-y-1 relative z-10 cursor-pointer">
			{t('cta.button')}
		</button>
	</div>
</section>
