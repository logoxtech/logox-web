---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="w-full border-t border-zinc-800/50 mt-10 py-8 relative z-10 w-full transition-colors">
	<div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-sm font-medium text-zinc-600">
		<p>&copy; {year} Logox. All rights reserved.</p>
		<div class="flex items-center gap-6 text-zinc-500">
			<a href={`/${lang}/about`} class="hover:text-zinc-300 transition-colors">{t('nav.about')}</a>
			<a href={`/${lang}/privacy`} class="hover:text-zinc-300 transition-colors">{t('nav.privacy')}</a>
			<a href={`/${lang}/contact`} class="hover:text-zinc-300 transition-colors">{t('nav.contact_page')}</a>
		</div>
	</div>
</footer>
