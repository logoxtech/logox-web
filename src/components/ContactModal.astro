---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="contact-modal"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden"
>
  <div
    id="contact-modal-overlay"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity"
  >
  </div>

  <div
    class="bg-[#1A1A1D]/90 backdrop-blur-md border border-zinc-700/50 rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl relative z-10 transform transition-all"
  >
    <button
      id="close-contact-modal"
      class="absolute top-4 right-4 text-zinc-400 hover:text-white transition-colors"
      aria-label="Close modal"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div id="modal-content-container">
      <h3 class="text-2xl font-bold text-zinc-200 mb-6">
        {t("contact.title")}
      </h3>

      <form id="contact-form" class="space-y-4">
        <div>
          <label for="name" class="block text-sm font-medium text-zinc-300 mb-1"
            >{t("contact.name")}
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 text-zinc-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#F97316] focus:border-transparent outline-none transition-all placeholder-zinc-500"
            placeholder="Jane Doe"
          />
        </div>

        <div>
          <label
            for="email"
            class="block text-sm font-medium text-zinc-300 mb-1"
            >{t("contact.email")}
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 text-zinc-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#F97316] focus:border-transparent outline-none transition-all placeholder-zinc-500"
            placeholder="jane@example.com"
          />
        </div>

        <div>
          <label
            for="message"
            class="block text-sm font-medium text-zinc-300 mb-1"
            >{t("contact.message")}
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 text-zinc-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#F97316] focus:border-transparent outline-none transition-all resize-none placeholder-zinc-500"
            placeholder="..."></textarea>
        </div>

        <button
          type="submit"
          class="bg-[#F97316] hover:bg-orange-600 text-white w-full py-3 rounded-lg font-bold transition-colors mt-2"
        >
          {t("contact.submit")}
        </button>
      </form>
    </div>
  </div>
</div>

<script define:vars={{ successText: t("contact.success") }}>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("contact-modal");
    const overlay = document.getElementById("contact-modal-overlay");
    const closeBtn = document.getElementById("close-contact-modal");
    const form = document.getElementById("contact-form");
    const triggerBtns = document.querySelectorAll(".open-contact-modal");
    const contentContainer = document.getElementById("modal-content-container");

    const openModal = (e) => {
      e.preventDefault();
      modal.classList.remove("hidden");
    };

    const closeModal = () => {
      modal.classList.add("hidden");
    };

    triggerBtns.forEach((btn) => btn.addEventListener("click", openModal));
    closeBtn.addEventListener("click", closeModal);
    overlay.addEventListener("click", closeModal);

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerText;

      // --- UI: estado de carga ---
      submitBtn.innerText = "Enviando...";
      submitBtn.disabled = true;

      // Captura de campos con FormData → JSON
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch(
          "http://35.226.145.153:5679/webhook-test/logox-lead.v1",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          }
        );

        if (!response.ok) {
          // El servidor respondió con un status de error (4xx / 5xx)
          throw new Error(`Server error: ${response.status}`);
        }

        // --- UI: estado de éxito ---
        contentContainer.innerHTML = `
          <div class="text-center py-8">
            <svg class="w-16 h-16 text-[#10B981] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-2">¡Mensaje enviado!</h3>
            <p class="text-zinc-400">${successText}</p>
          </div>
        `;
      } catch (error) {
        // --- UI: estado de error ---
        console.error("Error al enviar el formulario:", error);

        // Revertir botón
        submitBtn.innerText = originalText;
        submitBtn.disabled = false;

        // Mostrar mensaje de error en el modal (sin alert())
        const existingError = form.querySelector("#form-error-msg");
        if (!existingError) {
          const errorMsg = document.createElement("p");
          errorMsg.id = "form-error-msg";
          errorMsg.className = "text-red-400 text-sm text-center mt-3";
          errorMsg.textContent =
            "Ocurrió un error al enviar. Por favor intenta de nuevo.";
          form.appendChild(errorMsg);
        }
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });
  });
</script>
