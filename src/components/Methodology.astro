---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const methods = [
	{ title: t('method_step1_title'), desc: t('method_step1_desc'), num: '01' },
	{ title: t('method_step2_title'), desc: t('method_step2_desc'), num: '02' },
	{ title: t('method_step3_title'), desc: t('method_step3_desc'), num: '03' }
];
---

<section class="max-w-6xl mx-auto px-4 py-20 relative z-10 border-t border-zinc-900/50">
	<div class="mb-16 text-center md:text-left">
		<h2 class="text-3xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-zinc-100 via-zinc-200 to-zinc-500 tracking-tight inline-block relative">
			{t('method_title')}
		</h2>
	</div>
	
	<div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
		{methods.map(method => (
			<div class="relative p-6 pt-10 z-10 bg-[#1A1A1D]/50 backdrop-blur-md rounded-2xl border border-zinc-700/50 overflow-hidden">
				<!-- Large transparent number in background -->
				<span class="text-6xl font-bold text-zinc-800/30 absolute -top-4 -left-2 z-[-1] select-none tracking-tighter">
					{method.num}
				</span>
				<h3 class="text-xl font-bold text-zinc-200 mb-3 tracking-wide flex items-center gap-2">
					<span class="text-[#10B981] font-mono text-sm opacity-70 border border-[#10B981]/30 rounded px-1.5 py-0.5">{method.num}</span>
					{method.title.substring(3)} <!-- Removing the "1. " from the literal dictionary since we are formatting it strictly -->
				</h3>
				<p class="text-zinc-400 leading-relaxed text-sm md:text-base">
					{method.desc}
				</p>
			</div>
		))}
	</div>
</section>
