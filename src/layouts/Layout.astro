---
import '../styles/global.css';
import ContactModal from '../components/ContactModal.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	lang?: string;
}

const { title, description, image = '/og-image.png', lang } = Astro.props;

const urlLang = getLangFromUrl(Astro.url);
const currentLang = lang || urlLang;
const t = useTranslations(currentLang as any);

const siteName = 'LOGOXTECH';
const metaTitle = title ? `${title} | ${siteName}` : 'LOGOXTECH - Agencia de Automatización y Desarrollo Web';
const metaDesc = description || 'Elevando tu negocio a través de la automatización inteligente y desarrollo web.';
const canonicalURL = new URL(Astro.url.pathname, 'https://logox.tech');
---

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Base -->
		<title>{metaTitle}</title>
		<meta name="description" content={metaDesc} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / WhatsApp / LinkedIn -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={metaDesc} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />
		<meta property="og:site_name" content={siteName} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={metaTitle} />
		<meta property="twitter:description" content={metaDesc} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />

		<!-- Robots -->
		<meta name="robots" content="index, follow" />

		<!-- Hreflang (bilingual) -->
		<link rel="alternate" hreflang="en" href="https://logox.tech/en/" />
		<link rel="alternate" hreflang="es" href="https://logox.tech/es/" />
		<link rel="alternate" hreflang="x-default" href="https://logox.tech/en/" />

		<!-- Google Analytics 4 — ID de medición: G-MT2MX3TC55 -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MT2MX3TC55"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-MT2MX3TC55');
		</script>

		<ClientRouter />
	</head>
	<body class="bg-gradient-to-b from-zinc-900 via-[#121214] to-[#09090B] text-zinc-200 antialiased min-h-screen relative overflow-x-hidden selection:bg-[#10B981]/30">
		<div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
			<div class="fixed top-0 left-0 w-[80vw] h-[60vh] bg-gradient-to-br from-[#F97316]/12 via-transparent to-transparent blur-[120px] pointer-events-none opacity-80 z-[-1]"></div>
			<div class="fixed bottom-0 right-0 w-[90vw] h-[70vh] bg-gradient-to-tl from-[#10B981]/25 via-transparent to-transparent blur-[160px] pointer-events-none opacity-90 z-[-1]"></div>
		</div>
		<slot />
		<ContactModal />
	</body>
</html>
