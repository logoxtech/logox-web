---
import '../styles/global.css';
import ContactModal from '../components/ContactModal.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title?: string;
	lang?: string;
}

const urlLang = getLangFromUrl(Astro.url);
const currentLang = Astro.props.lang || urlLang;
const t = useTranslations(currentLang as any);

const metaTitle = Astro.props.title || t('seo_title');
const metaDesc = t('seo_desc');
---

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={metaDesc} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={metaDesc} />
		<meta property="og:image" content="/favicon.svg" />
		<ViewTransitions />
	</head>
	<body class="bg-gradient-to-b from-zinc-900 to-[#121214] text-zinc-200 antialiased min-h-screen relative overflow-x-hidden selection:bg-[#10B981]/30">
		<div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
			<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#10B981]/10 to-transparent blur-[120px]"></div>
			<div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#F97316]/10 to-transparent blur-[120px]"></div>
		</div>
		<slot />
		<ContactModal />
	</body>
</html>
