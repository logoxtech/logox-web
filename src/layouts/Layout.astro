---
import '../styles/global.css';
import ContactModal from '../components/ContactModal.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	lang?: string;
}

const urlLang = getLangFromUrl(Astro.url);
const currentLang = Astro.props.lang || urlLang;
const t = useTranslations(currentLang as any);

const metaTitle = Astro.props.title || t('seo_title');
const metaDesc = t('seo_desc');
---

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={metaDesc} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={metaDesc} />
		<meta property="og:image" content="/favicon.svg" />
		<ClientRouter />
	</head>
	<body class="bg-gradient-to-b from-zinc-900 via-[#121214] to-[#09090B] text-zinc-200 antialiased min-h-screen relative overflow-x-hidden selection:bg-[#10B981]/30">
		<div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
			<div class="fixed top-0 left-0 w-[80vw] h-[60vh] bg-gradient-to-br from-[#F97316]/12 via-transparent to-transparent blur-[120px] pointer-events-none opacity-80 z-[-1]"></div>
			<div class="fixed bottom-0 right-0 w-[90vw] h-[70vh] bg-gradient-to-tl from-[#10B981]/25 via-transparent to-transparent blur-[160px] pointer-events-none opacity-90 z-[-1]"></div>
		</div>
		<slot />
		<ContactModal />
	</body>
</html>
