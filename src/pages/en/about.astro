---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout lang={lang} title={`${t('nav.about')} | Logox`} description="Learn how Logox approaches digital systems: direct work, fixed-price delivery, and technology stacks we know deeply. No account managers, no fluff.">
	<Navbar />
	<main class="py-24 md:py-32 px-4 relative z-10 min-h-[80vh] flex flex-col justify-center">
		<div class="max-w-3xl mx-auto text-center mb-16">
			<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-zinc-100 via-zinc-200 to-zinc-500 mb-6" style="view-transition-name: about-title;">
				{t('about_title')}
			</h1>
			<p class="text-xl text-zinc-400 font-medium">
				{t('about_subtitle')}
			</p>
		</div>

		<article class="prose prose-invert prose-zinc max-w-3xl mx-auto text-zinc-300 leading-relaxed text-lg marker:text-[#10B981]">
			<h2>{t('about_manifesto')}</h2>
			<p>{t('about_text1')}</p>
			<p>{t('about_text2')}</p>
		</article>

		<!-- ── How We Work ──────────────────────────────────────── -->
		<section class="max-w-3xl mx-auto mt-20 pt-16 border-t border-zinc-800/50 w-full">
			<h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-4">{t('about_how_title')}</h2>
			<p class="text-[#F97316] font-semibold text-lg mb-5">{t('about_how_lead')}</p>
			<p class="text-zinc-300 leading-relaxed mb-4">{t('about_how_p1')}</p>
			<p class="text-zinc-300 leading-relaxed">{t('about_how_p2')}</p>
		</section>

		<!-- ── Our Stack ────────────────────────────────────────── -->
		<section class="max-w-3xl mx-auto mt-16 pt-16 border-t border-zinc-800/50 w-full">
			<h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-3">{t('about_stack_title')}</h2>
			<p class="text-zinc-400 mb-6">{t('about_stack_intro')}</p>
			<dl class="space-y-3 mb-6">
				<div class="flex flex-col sm:flex-row sm:gap-3">
					<dt class="text-sm font-bold text-[#F97316] sm:w-44 shrink-0">{t('about_stack_cat1')}</dt>
					<dd class="text-zinc-300 text-sm">{t('about_stack_cat1_tools')}</dd>
				</div>
				<div class="flex flex-col sm:flex-row sm:gap-3">
					<dt class="text-sm font-bold text-[#F97316] sm:w-44 shrink-0">{t('about_stack_cat2')}</dt>
					<dd class="text-zinc-300 text-sm">{t('about_stack_cat2_tools')}</dd>
				</div>
				<div class="flex flex-col sm:flex-row sm:gap-3">
					<dt class="text-sm font-bold text-[#F97316] sm:w-44 shrink-0">{t('about_stack_cat3')}</dt>
					<dd class="text-zinc-300 text-sm">{t('about_stack_cat3_tools')}</dd>
				</div>
				<div class="flex flex-col sm:flex-row sm:gap-3">
					<dt class="text-sm font-bold text-[#F97316] sm:w-44 shrink-0">{t('about_stack_cat4')}</dt>
					<dd class="text-zinc-300 text-sm">{t('about_stack_cat4_tools')}</dd>
				</div>
			</dl>
			<p class="text-zinc-500 text-sm italic">{t('about_stack_closing')}</p>
		</section>

		<!-- ── Company Facts ────────────────────────────────────── -->
		<section class="max-w-3xl mx-auto mt-16 pt-16 border-t border-zinc-800/50 w-full">
			<h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-8">{t('about_facts_title')}</h2>
			<dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-6">
				<div>
					<dt class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">{t('about_facts_founded')}</dt>
					<dd class="text-zinc-200 font-medium">{t('about_facts_founded_val')}</dd>
				</div>
				<div>
					<dt class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">{t('about_facts_hq')}</dt>
					<dd class="text-zinc-200 font-medium">{t('about_facts_hq_val')}</dd>
				</div>
				<div>
					<dt class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">{t('about_facts_focus')}</dt>
					<dd class="text-zinc-200 font-medium">{t('about_facts_focus_val')}</dd>
				</div>
				<div>
					<dt class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">{t('about_facts_model')}</dt>
					<dd class="text-zinc-200 font-medium">{t('about_facts_model_val')}</dd>
				</div>
			</dl>
		</section>

		<div class="max-w-3xl mx-auto text-center mt-20 border-t border-zinc-800/50 pt-16 w-full">
			<button class="open-contact-modal bg-[#F97316] hover:bg-orange-600 shadow-[0_0_30px_rgba(249,115,22,0.15)] text-white px-8 py-4 rounded-xl font-bold transition-all transform hover:scale-105 cursor-pointer">
				{t('contact.submit')}
			</button>
		</div>
	</main>
	<Footer />
</Layout>
